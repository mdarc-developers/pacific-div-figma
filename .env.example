# Copy this file to .env and fill in your Firebase project values.
# Get these values from the Firebase Console → Project Settings → Your apps → SDK setup and configuration.
# See FIREBASE_SETUP.md for full instructions.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Firebase Cloud Messaging VAPID key for Prize cloud alerts (web push notifications).
# Generate it in the Firebase Console → Project Settings → Cloud Messaging
# → Web Push certificates → Generate key pair.
# The value shown is the "Key pair" public key (a base64url string).
VITE_FIREBASE_VAPID_KEY=

# Google Drive folder ID for prize/prizewinner file uploads (Prizes admin).
# Create a folder in Google Drive, share it appropriately, and paste its ID here.
# The folder ID is the last path component of the Drive folder URL.
VITE_GOOGLE_DRIVE_FOLDER_ID=

# Google Drive folder ID for prize image uploads (Prizes admin image library).
# Create a separate folder in Google Drive for prize images and paste its ID here.
VITE_GOOGLE_DRIVE_FOLDER_PRIZES_ID=

# ---------------------------------------------------------------------------
# Twilio — SMS prize winner notifications (Cloud Function: notifyPrizeWinner)
# ---------------------------------------------------------------------------
# These are Firebase Secret Manager secrets, NOT regular environment variables.
# They are NOT loaded from this .env file at runtime.
# Provision them once before deploying Cloud Functions:
#
#   firebase functions:secrets:set TWILIO_ACCOUNT_SID
#   firebase functions:secrets:set TWILIO_AUTH_TOKEN
#   firebase functions:secrets:set TWILIO_PHONE_NUMBER
#
# TWILIO_ACCOUNT_SID   — Your Twilio Account SID (starts with "AC…")
#                        Found at: https://console.twilio.com → Account Dashboard
# TWILIO_AUTH_TOKEN    — Your Twilio Auth Token
#                        Found at: https://console.twilio.com → Account Dashboard
# TWILIO_PHONE_NUMBER  — The Twilio "From" phone number in E.164 format (e.g. +12125551234)
#                        Must be a Twilio-purchased or verified number with SMS capability
#
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
