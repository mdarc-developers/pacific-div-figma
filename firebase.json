{
  "firestore": {
    "rules": "firestore.rules"
  },
  "functions": {
    "source": "functions",
    "ignore": [
      "node_modules",
      ".git",
      "firebase-debug.log",
      "firebase-debug.*.log",
      "*.local"
    ]
  },
  "hosting": [
    {
      "target": "app",
      "public": "dist",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**",
        "index-firebase.html"
      ],
      "headers": [
        {
          "source": "/sw.js",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache"
            },
            {
              "key": "Service-Worker-Allowed",
              "value": "/"
            }
          ]
        },
        {
          "source": "/manifest.webmanifest",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache"
            }
          ]
        }
      ],
      "rewrites": [
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    },
    {
      "target": "quartzfestRedirect",
      "public": "public-redirect",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "redirects": [
        {
          "source": "**",
          "destination": "https://pacific-div.web.app/quartzfest",
          "type": 301
        }
      ]
    },
    {
      "target": "hamcationRedirect",
      "public": "public-redirect",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "redirects": [
        {
          "source": "**",
          "destination": "https://pacific-div.web.app/hamcation",
          "type": 301
        }
      ]
    },
    {
      "target": "yumaRedirect",
      "public": "public-redirect",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "redirects": [
        {
          "source": "**",
          "destination": "https://pacific-div.web.app/yuma",
          "type": 301
        }
      ]
    },
    {
      "target": "hamventionRedirect",
      "public": "public-redirect",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "redirects": [
        {
          "source": "**",
          "destination": "https://pacific-div.web.app/hamvention",
          "type": 301
        }
      ]
    },
    {
      "target": "seapacRedirect",
      "public": "public-redirect",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "redirects": [
        {
          "source": "**",
          "destination": "https://pacific-div.web.app/seapac",
          "type": 301
        }
      ]
    },
    {
      "target": "huntsvilleRedirect",
      "public": "public-redirect",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "redirects": [
        {
          "source": "**",
          "destination": "https://pacific-div.web.app/huntsville",
          "type": 301
        }
      ]
    },
    {
      "target": "pacificonRedirect",
      "public": "public-redirect",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "redirects": [
        {
          "source": "**",
          "destination": "https://pacific-div.web.app/pacificon",
          "type": 301
        }
      ]
    }
  ]
}
