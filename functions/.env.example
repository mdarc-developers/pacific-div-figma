# Copy this file to functions/.env (never commit .env — it is git-ignored)
# and fill in the values for your GCP project before running:
#   firebase deploy --only functions

# ---------------------------------------------------------------------------
# FUNCTION_SERVICE_ACCOUNT
# ---------------------------------------------------------------------------
# The runtime service account for the sendWelcomeEmail Cloud Function v2.
#
# Firebase CLI historically defaults to the legacy App Engine default service
# account (project-id@appspot.gserviceaccount.com) when granting Secret Manager
# IAM access for blocking functions.  That account no longer exists in projects
# that never enabled App Engine, causing deployment to fail with HTTP 400.
#
# Setting this param overrides that default and tells Firebase CLI to grant the
# Compute Engine default service account access to GMAIL_SERVICE_ACCOUNT_JSON
# and GMAIL_SENDER_EMAIL instead.
#
# How to find your project number:
#   https://console.cloud.google.com/iam-admin/settings
#   (it is the numeric value shown under "Project number")
#
# Then substitute it below:
FUNCTION_SERVICE_ACCOUNT=123456789-compute@developer.gserviceaccount.com
