{
  "name": "pacific-div-functions",
  "version": "1.0.0",
  "description": "Firebase Cloud Functions for the Pacific Division Conference App",
  "main": "lib/index.js",
  "scripts": {
    "fbf": "npm install firebase-functions@latest firebase-admin@latest --save",
    "fbt": "npm install -g firebase-tools",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "test": "vitest run --config vitest.config.ts"
  },
  "engines": {
    "node": "24"
  },
  "dependencies": {
    "firebase-admin": "^13.7.0",
    "firebase-functions": "^7.1.0",
    "google-auth-library": "^10.1.0",
    "googleapis": "^171.4.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "private": true
}
