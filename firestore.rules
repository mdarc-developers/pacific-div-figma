rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: returns true when the authenticated user is listed in the
    // groups/mdarc-developers document.  That document must be created via the
    // Firebase Console or admin SDK with the structure:
    //   { members: { "<uid>": true, "<uid2>": true, ... } }
    // See FIREBASE_SETUP.md §5 for setup instructions.
    // A single get() is used; if the document does not exist, get() returns
    // null and the expression safely evaluates to false (access denied).
    function isMdarcDeveloper() {
      return request.auth != null
        && get(/databases/$(database)/documents/groups/mdarc-developers).data.members.get(request.auth.uid, false) == true;
    }

    // Helper: returns true when the authenticated user is listed in the
    // groups/prize-admin document.  That document must be created via the
    // Firebase Console or admin SDK with the same structure as mdarc-developers:
    //   { members: { "<uid>": true, "<uid2>": true, ... } }
    // See FIREBASE_SETUP.md §5 for setup instructions.
    function isPrizeAdmin() {
      return request.auth != null
        && get(/databases/$(database)/documents/groups/prize-admin).data.members.get(request.auth.uid, false) == true;
    }

    // Helper: returns true when the authenticated user is listed in the
    // groups/user-admin document.  That document must be created via the
    // Firebase Console or admin SDK with the same structure:
    //   { members: { "<uid>": true, "<uid2>": true, ... } }
    function isUserAdmin() {
      return request.auth != null
        && get(/databases/$(database)/documents/groups/user-admin).data.members.get(request.auth.uid, false) == true;
    }

    // Helper: returns true when the authenticated user has a "real profile"
    // (non-empty displayName field in their users/{uid} document).
    // Used to gate protected writes such as posting messages.
    function hasRealProfile() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return request.auth != null
        && userDoc != null
        && userDoc.data.displayName is string
        && userDoc.data.displayName.size() > 0;
    }

    // ── Conferences, Sessions, Maps — public read ─────────────────────────
    match /conferences/{conferenceId} {
      allow read: if true;
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // ── Conference attendees — owner-only; not exposed as a public list.
    // The primary record is written/deleted by the authenticated user for their own uid.
    // Admin read is allowed for mdarc-developers.
    match /conferences/{conferenceId}/attendees/{uid} {
      allow read: if (request.auth != null && request.auth.uid == uid)
        || isMdarcDeveloper();
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    match /sessions/{sessionId} {
      allow read: if true;
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    match /maps/{mapId} {
      allow read: if true;
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // ── Users — own doc only; mdarc-developers may list/count the collection
    match /users/{userId} {
      allow get: if request.auth != null && request.auth.uid == userId;
      allow list: if isMdarcDeveloper();
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Audit logs — users may create entries in their own subcollection;
    //    mdarc-developers and user-admins may read all audit logs for compliance review.
    match /users/{userId}/auditLog/{entryId} {
      allow create: if request.auth != null && request.auth.uid == userId;
      allow read: if (request.auth != null && request.auth.uid == userId)
        || isMdarcDeveloper()
        || isUserAdmin();
      allow update, delete: if false;
    }

    // ── Groups — readable by authenticated users; written via admin SDK only
    match /groups/{groupId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Stats — signupCounter is public; other stat docs require mdarc-developers
    match /stats/signupCounter {
      allow read: if true;
      allow write: if false;
    }
    match /stats/{document} {
      allow read: if isMdarcDeveloper();
      allow write: if false;
    }

    // ── Prizes — public read; admin write ─────────────────────────────────
    match /prizes/{prizeId} {
      allow read: if true;
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // ── Prize winners — own wins or admin ────────────────────────────────
    match /prizeWinners/{winnerId} {
      allow read: if request.auth != null
        && (resource.data.winnerEmail == request.auth.token.email
          || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true
          || isPrizeAdmin()
          || isMdarcDeveloper());
      allow write: if isPrizeAdmin() || isMdarcDeveloper();
    }

    // ── Bookmark counts — public read; authenticated write ────────────────
    match /bookmarkCounts/{conferenceId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── Vote counts — public read; server-only write ──────────────────────
    // Clients must use the castVote Cloud Function (HTTPS Callable) to update
    // vote counts.  The Cloud Functions service account (admin SDK) bypasses
    // these rules and is the only writer.  Direct client writes are denied to
    // prevent vote-count manipulation.
    match /voteCounts/{conferenceId} {
      allow read: if true;
      allow write: if false;
    }

    // ── Public Profiles — readable by authenticated users with verified email;
    // owner may write their own entry.
    // Documents contain only: uid, displayName, callsign, displayProfile.
    // Sensitive fields (email, groups, sessions, exhibitors, prizesDonated)
    // are intentionally excluded from this collection.
    // The syncPublicProfile Cloud Function maintains these documents.
    // Clients may also write their own entry to support immediate UI updates.
    match /publicProfiles/{uid} {
      allow read: if request.auth != null && request.auth.token.email_verified == true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Messages ──────────────────────────────────────────────────────────
    match /messages/{messageId} {
      allow read: if resource.data.isPublic == true
        || (request.auth != null
          && (resource.data.from == request.auth.uid || resource.data.to == request.auth.uid));
      allow create: if hasRealProfile();
      allow update: if request.auth != null && resource.data.from == request.auth.uid;
      allow delete: if request.auth != null && resource.data.from == request.auth.uid;
    }
  }
}
